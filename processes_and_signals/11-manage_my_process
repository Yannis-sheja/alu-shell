#!/usr/bin/env bash
# This script manages (starts, stops, restarts) the manage_my_process daemon
PIDFILE="/var/run/my_process.pid"
DAEMON="$(dirname "$0")/manage_my_process"

case "$1" in
    start)
        "$DAEMON" &
        echo "$!" > "$PIDFILE"
        echo "manage_my_process started"
        ;;
    stop)
        kill "$(cat "$PIDFILE")"
        rm -f "$PIDFILE"
        echo "manage_my_process stopped"
        ;;
    restart)
        kill "$(cat "$PIDFILE")"
        rm -f "$PIDFILE"
        "$DAEMON" &
        echo "$!" > "$PIDFILE"
        echo "manage_my_process restarted"
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        ;;
esac
